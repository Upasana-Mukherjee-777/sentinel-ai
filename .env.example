# Copy this file to .env and fill in real values before deploying anywhere
# beyond local docker-compose.

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_dev_password

POSTGRES_DSN=postgresql://sentinel:sentinel_dev_password@localhost:5432/sentinel

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333

